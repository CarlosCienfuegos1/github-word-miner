# ── Requerido ──────────────────────────────────────────────────────
# Token de acceso personal desde https://github.com/settings/tokens
# Solo necesita el scope read:public_repo (o ninguno para repos públicos).
# Sin token, la API de GitHub permite solo 10 requests por minuto.
GITHUB_TOKEN=

# ── Opcional ───────────────────────────────────────────────────────
# Máximo de archivos fuente a parsear por repositorio
MAX_FILES_PER_REPO=2

# Repositorios a obtener por página de la API (se recomienda 1–5)
REPOS_PER_PAGE=3

# Segundos de espera entre descargas de archivos dentro de un repo
SLEEP_BETWEEN_FILES=8

# Segundos de espera entre repositorios
SLEEP_BETWEEN_REPOS=15

# Longitud mínima de caracteres para incluir una palabra en el conteo
MIN_WORD_LENGTH=2

# Cantidad de palabras mostradas en el dashboard por defecto
DEFAULT_TOP_N=20

# Segundos entre cada envío SSE al navegador
SSE_INTERVAL=3.0

# Puerto del host para el dashboard web (por defecto: 5000)
VISUALIZER_PORT=5000
