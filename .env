# ── Required ──────────────────────────────────────────────────────
# Personal access token from https://github.com/settings/tokens
# Only needs read:public_repo scope (or no scope for public repos).
# Without a token the GitHub API allows only 10 requests/minute.
GITHUB_TOKEN=ghp_your_token_here

# ── Optional ──────────────────────────────────────────────────────
# Max source files to parse per repository (reduce to avoid rate limits)
MAX_FILES_PER_REPO=30

# Repos to fetch per API page (1–5 recommended)
REPOS_PER_PAGE=5

# Seconds to wait between file fetches within a repo
SLEEP_BETWEEN_FILES=0.3

# Seconds to wait between repositories
SLEEP_BETWEEN_REPOS=2.0

# Minimum word length to include in counts
MIN_WORD_LENGTH=2

# Top-N words shown in the dashboard by default
DEFAULT_TOP_N=20

# Seconds between SSE pushes to the browser
SSE_INTERVAL=3.0

# Host port for the dashboard (default: 5000)
VISUALIZER_PORT=5000
